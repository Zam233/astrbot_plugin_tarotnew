{
    "enable_daily_reminder": {
        "description": "是否启用每日抽牌提醒",
        "type": "bool",
        "default": false,
        "hint": "启用后每天自动提醒用户抽牌"
    },
    "reminder_time": {
        "description": "每日提醒时间（24小时制）",
        "type": "string",
        "default": "08:00",
        "hint": "格式：HH:MM"
    },
    "enable_image": {
        "description": "是否显示牌面图片",
        "type": "bool",
        "default": true,
        "hint": "关闭后仅显示文字信息"
    },
    "default_card_count": {
        "description": "默认占卜抽牌数量",
        "type": "int",
        "default": 3,
        "hint": "可选值：1-3",
        "options": [1, 2, 3]
    }
}